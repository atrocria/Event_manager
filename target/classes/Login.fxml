<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>

<HBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.LoginController">
   <children>
      <TextField fx:id="emailField" promptText="email" />
      <PasswordField fx:id="passwordField" promptText="password" />
      <Button fx:id="loginBttn" mnemonicParsing="false" onAction="#handleLogin" text="Login" />
      <Button fx:id="registerBttn" mnemonicParsing="false" onAction="#handleRegisterNavigation" text="Register" />
   </children>
</HBox>
