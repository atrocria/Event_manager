<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.StaffPageController">
   <children>
      <VBox spacing="15.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
         <children>
            <Text text="Staff Management Portal" style="-fx-font-size: 24; -fx-font-weight: bold;" />
            
            <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
              <tabs>
                <Tab text="Attendee Check-in">
                  <content>
                    <VBox spacing="10.0" style="-fx-padding: 15;">
                       <children>
                          <HBox spacing="10.0" alignment="CENTER_LEFT">
                             <children>
                                <TextField fx:id="txtSearchAttendee" promptText="Search Name or Event ID..." HBox.hgrow="ALWAYS" />
                                <Button text="Refresh" onAction="#loadAttendeeData" />
                             </children>
                          </HBox>
                          <TableView fx:id="tblAttendance" VBox.vgrow="ALWAYS">
                            <columns>
                              <TableColumn fx:id="colUser" prefWidth="120.0" text="User Name" />
                              <TableColumn fx:id="colEvent" prefWidth="180.0" text="Event" />
                              <TableColumn fx:id="colStatus" prefWidth="100.0" text="Attendance" />
                              <TableColumn fx:id="colPaymentStatus" prefWidth="100.0" text="Payment" /> <TableColumn fx:id="colAction" prefWidth="100.0" text="Check-In" />
                            </columns>
                          </TableView>
                       </children>
                    </VBox>
                  </content>
                </Tab>

                <Tab text="Manage Permissions">
                  <content>
                    <VBox spacing="10.0" style="-fx-padding: 15;">
                       <children>
                          <Label text="Manage Attendee Roles" style="-fx-font-weight: bold;" />
                          <TableView fx:id="tblUsers" VBox.vgrow="ALWAYS">
                            <columns>
                              <TableColumn fx:id="colUserName" prefWidth="200.0" text="Email/Username" />
                              <TableColumn fx:id="colCurrentRole" prefWidth="150.0" text="Current Role" />
                              <TableColumn fx:id="colRoleAction" prefWidth="200.0" text="Set Role" />
                            </columns>
                          </TableView>
                       </children>
                    </VBox>
                  </content>
                </Tab>
              </tabs>
            </TabPane>
         </children>
      </VBox>
   </children>
</AnchorPane>