<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane minHeight="600.0" minWidth="1000.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.MainController">
   <top>
      <HBox prefHeight="29.0" prefWidth="1000.0" style="-fx-background-color: D3D3D3;" BorderPane.alignment="CENTER">
         <children>
            <Label prefWidth="56.0" text="I'm a" textAlignment="CENTER">
               <padding>
                  <Insets left="5.0" />
               </padding>
            </Label>
            <ComboBox fx:id="roleSelector" prefWidth="150.0" />
            <Region prefHeight="0.0" prefWidth="626.0" HBox.hgrow="ALWAYS" />
            <Button minWidth="50.0" mnemonicParsing="false" text="--" />
            <Button minWidth="50.0" mnemonicParsing="false" prefHeight="29.0" text="O" />
            <Button minWidth="28.0" mnemonicParsing="false" onAction="#handleCloseButton" prefHeight="30.0" text="X" />
         </children></HBox>
   </top>
   <left>
      <VBox fillWidth="false" maxWidth="-Infinity" prefWidth="56.0" style="-fx-background-color: D3D3D3;" BorderPane.alignment="CENTER">
         <children>
            <Button mnemonicParsing="false" onAction="#handleDashboardButton" text="Dash" />
            <Button mnemonicParsing="false" text="events" />
            <Button mnemonicParsing="false" text="Button" />
            <Button mnemonicParsing="false" text="Button" />
            <Button mnemonicParsing="false" text="Button" />
            <Region prefHeight="275.0" prefWidth="54.0" VBox.vgrow="ALWAYS" />
            <Button mnemonicParsing="false" onAction="#handleSettingsButton" text="settings" />
            <Button mnemonicParsing="false" text="profile" />
         </children>
      </VBox>
   </left>
   <center>
      <AnchorPane fx:id="contentArea" prefHeight="193.0" prefWidth="944.0" BorderPane.alignment="CENTER" />
   </center>
</BorderPane>
