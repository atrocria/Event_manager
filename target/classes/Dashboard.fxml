<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #1a1a1a;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.DashboardController">
   <children>
      <VBox spacing="25.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </padding>
         <children>
            <HBox spacing="20.0">
               <children>
                  <VBox style="-fx-background-color: #2d2d2d; -fx-background-radius: 10; -fx-padding: 20;" HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="Total Events" textFill="#bdc3c7" />
                        <Label fx:id="lblTotalEvents" text="0" textFill="WHITE">
                           <font><Font name="System Bold" size="28.0" /></font>
                        </Label>
                     </children>
                  </VBox>
                  <VBox style="-fx-background-color: #2d2d2d; -fx-background-radius: 10; -fx-padding: 20;" HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="My Registrations" textFill="#bdc3c7" />
                        <Label fx:id="lblMyRegistrations" text="0" textFill="#2ecc71">
                           <font><Font name="System Bold" size="28.0" /></font>
                        </Label>
                     </children>
                  </VBox>
                  <VBox style="-fx-background-color: #2d2d2d; -fx-background-radius: 10; -fx-padding: 20;" HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="Current Role" textFill="#bdc3c7" />
                        <Label fx:id="lblRoleLevel" text="ATTENDEE" textFill="#3498db">
                           <font><Font name="System Bold" size="20.0" /></font>
                        </Label>
                     </children>
                  </VBox>
               </children>
            </HBox>

            <VBox spacing="10.0" VBox.vgrow="ALWAYS">
               <children>
                  <Label text="Upcoming Events" textFill="WHITE">
                     <font><Font name="System Bold" size="18.0" /></font>
                  </Label>
                  <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                     <content>
                        <FlowPane fx:id="eventGrid" hgap="20.0" vgap="20.0" style="-fx-background-color: #1a1a1a;" />
                     </content>
                  </ScrollPane>
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>