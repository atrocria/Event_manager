<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="500.0" prefWidth="850.0" style="-fx-background-color: #1a1a1a;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.ShowTicketController">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="15.0">
               <children>
                  <Text fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" text="My Booked Tickets">
                     <font>
                        <Font name="System Bold" size="26.0" />
                     </font>
                  </Text>
                  <Separator opacity="0.2" HBox.hgrow="ALWAYS" />
               </children>
            </HBox>
            
            <TableView fx:id="tblTickets" prefHeight="400.0" prefWidth="790.0" style="-fx-background-color: #2c3e50; -fx-text-fill: white;">
               <columns>
                  <TableColumn fx:id="colEvent" prefWidth="250.0" text="Event Name" />
                  <TableColumn fx:id="colBookingId" prefWidth="180.0" text="Booking ID (Check-in)" />
                  <TableColumn fx:id="colSeat" prefWidth="100.0" text="Seat No." />
                  <TableColumn fx:id="colPaid" prefWidth="120.0" text="Price Paid" />
                  <TableColumn fx:id="colStatus" prefWidth="120.0" text="Status" />
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
            
            <HBox alignment="CENTER_RIGHT">
               <children>
                  <Label text="* Present Booking ID at front desk for entry" textFill="#95a5a6">
                     <font>
                        <Font name="System Italic" size="12.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>